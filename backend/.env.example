# ─── JJ Studio ERP — Backend environment (TEMPLATE) ──────────────────────────
# Copy to backend/.env on the server and fill in real values. NEVER commit .env.

# ── Core ─────────────────────────────────────────────────────────────────────
# Full replica-set host list (NOT mongodb+srv:// — SRV DNS is blocked on the
# prod network). The driver discovers the primary and survives elections.
MONGO_URI=mongodb://user:pass@host1:27017,host2:27017,host3:27017/jj_studio?replicaSet=rs0&authSource=admin
# Backend listen port. On the shared EC2 host this is 5003 (NGINX proxies
# /api → 127.0.0.1:5003); 5000/5001/5002 belong to other apps on the box.
PORT=5003

# JWT — set a strong secret in production (code falls back to "secretkey").
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ── Email (Gmail SMTP via Nodemailer) ────────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── OpenAI (AI assistant) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp (Maytapi) ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=
MAYTAPI_PRODUCT_ID=
MAYTAPI_PHONE_ID=
WELCOME_WHATSAPP_DELAY_MINUTES=5

# ── Feature flags ────────────────────────────────────────────────────────────
WORKFLOW_ENGINE_V1=true
WORKFLOW_GATES_ENABLED=false
PMS_REMINDERS_ENABLED=true

# ── AWS S3 — drawing storage ─────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=jjstudio-erp
S3_DRAWINGS_PREFIX=drawings
