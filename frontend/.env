# VITE_API_URL="http://3.108.106.233:5000/api"
VITE_API_URL="http://localhost:5000/api"

# Feature flags
# Toggles all AI surface area in the UI (chat launcher, "Ask AI" buttons,
# AI hint banners, AI inline-polish). Set to "false" for the client demo
# build to hide every AI element while keeping the code in place for future.
# Vite reads booleans as strings — anything other than the literal "true"
# is treated as disabled.
VITE_ENABLE_AI=true

# Toggles the entire KIT (Keep In Touch) module in the UI: the sidebar "KIT"
# section, all /kit routes, and the communication timeline on project pages.
# Set to "false" for the client build to hide KIT while keeping the code in
# place. Same string-boolean rule as above — only the literal "true" enables it.
VITE_ENABLE_KIT=true