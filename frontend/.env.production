# Production / client-demo build overrides.
# Vite auto-loads this file for `npm run build` (mode = production).

# Hide all AI features from the client demo. Flip back to "true" once the
# AI chatbot is ready to ship.
VITE_ENABLE_AI=false

# Hide the entire KIT module from the client build. Flip back to "true" to ship.
VITE_ENABLE_KIT=false
